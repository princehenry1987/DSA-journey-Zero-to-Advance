class Solution {
    public int maxArea(int[] height) {
        int start =0;
        int end = height.length-1;
        int Maxarea=0;
        while(start<end){
            int currarea= (end - start)*Math.min(height[end],height[start]);
            if(currarea>Maxarea){
                Maxarea = currarea;
                

            }if(height[end]>height[start]){
                start++;
            }else{
                end--;
            }
        }
        return Maxarea;
    }
}
