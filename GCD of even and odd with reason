class Solution {
    public int gcdOfOddEvenSums(int n) {
        int sumodd=0;
        int sumeven =0;
        
        for(int i=1;i<=n;i++){
            sumodd+=(2*i-1);
            sumeven+=(2*i);
        }
       return gcd(sumeven,sumodd);
    }
    public int gcd(int sumeven, int sumodd){
        if(sumeven==0) return sumodd;
        return  gcd(sumodd%sumeven,sumeven);
        
        }
    
}
