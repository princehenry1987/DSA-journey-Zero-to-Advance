class Solution {
    public int findGCD(int[] nums) {
        int max=nums[0];
        int min=nums[0];
        for(int i=0;i<nums.length;i++){
            if(nums[i]<min ){
                min=nums[i];
            }
            if(nums[i]>max){
                max=nums[i];
            }
             
        }
        return gcd(max,min);
    }
     public int gcd(int max,int min){
         if(max==0) return min;
         return gcd(min%max,max);
     }
}
